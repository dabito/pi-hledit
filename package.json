{
  "name": "pi-hledit",
  "version": "1.1.7",
  "description": "Pi wrapper for hledit hash-anchored file edits. Rejects stale writes before they happen for AI coding agents.",
  "type": "module",
  "main": "index.ts",
  "license": "MIT",
  "author": "dabito",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dabito/pi-hledit.git"
  },
  "bugs": {
    "url": "https://github.com/dabito/pi-hledit/issues"
  },
  "homepage": "https://github.com/dabito/pi-hledit#readme",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "agent-tool",
    "hledit",
    "hashline",
    "hashline-edit",
    "hash-anchored",
    "stale-write",
    "stale-edit",
    "file-editing",
    "context-safe",
    "local-first",
    "ai-agent",
    "coding-agents"
  ],
  "files": [
    "index.ts",
    "test",
    "tsconfig.json",
    "tsconfig.contract.json",
    "eslint.config.js",
    "README.md",
    "CHANGELOG.md",
    "docs/demo",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "npm run typecheck && npm run contract && npm run lint",
    "contract": "rm -rf .tmp-tests && tsc -p tsconfig.contract.json && node --test .tmp-tests/test/*.test.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.79.9",
    "typebox": "^1.0.55"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.61.1"
  },
  "engines": {
    "node": ">=18"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "image": "https://raw.githubusercontent.com/dabito/pi-hledit/main/docs/demo/pi-hledit.png"
  }
}
