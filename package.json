{
  "name": "pi-hledit",
  "version": "1.0.1",
  "description": "Hashline edit support for Pi: the hledit hash-anchored file editing extension for AI coding agents.",
  "type": "module",
  "main": "index.ts",
  "license": "MIT",
  "author": "dabito",
  "repository": {
    "type": "git",
    "url": "https://github.com/dabito/pi-hledit"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "hledit",
    "hashline",
    "hashline-edit",
    "hash-line-edit",
    "hash-anchored",
    "file-editing",
    "ai-agent"
  ],
  "files": [
    "index.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "npm run typecheck",
    "typecheck": "tsc --noEmit --strict --skipLibCheck index.ts"
  },
  "dependencies": {
