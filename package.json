  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
